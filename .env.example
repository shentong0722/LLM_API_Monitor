LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-REPLACE_ME
LLM_MODEL=gpt-4o-mini
# Optional: monitor multiple models from the same OpenAI-compatible upstream.
LLM_MODELS=gpt-4o-mini,gpt-4.1-mini
# Optional advanced mode: JSON array for different upstreams or per-model settings.
# LLM_TARGETS=[{"id":"openai-mini","label":"OpenAI Mini","model":"gpt-4o-mini","base_url":"https://api.openai.com/v1","api_key":"sk-REPLACE_ME"},{"id":"deepseek","label":"DeepSeek","model":"deepseek-chat","base_url":"https://api.deepseek.com/v1","api_key":"sk-REPLACE_ME"}]
LLM_PROMPT=Reply with one short sentence about API latency monitoring.
LLM_MAX_TOKENS=80
LLM_PROBE_INTERVAL_SECONDS=60
LLM_PROBE_TIMEOUT_MS=30000
LLM_PROBE_MODE=parallel
LLM_PROBE_STAGGER_MS=0
LLM_STREAM_OPTIONS_INCLUDE_USAGE=true
PROBE_CRON_SECRET=replace-with-a-long-random-token

# Optional threshold tuning for the public status badge.
LLM_TTFT_DEGRADED_MS=3000
LLM_TPS_DEGRADED_BELOW=5

# Optional KV binding variable name in EdgeOne Pages should be:
# LLM_MONITOR_KV

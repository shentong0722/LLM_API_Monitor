LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-REPLACE_ME
LLM_MODEL=gpt-4o-mini
LLM_PROMPT=Reply with one short sentence about API latency monitoring.
LLM_MAX_TOKENS=80
LLM_PROBE_INTERVAL_SECONDS=60
LLM_PROBE_TIMEOUT_MS=30000
LLM_STREAM_OPTIONS_INCLUDE_USAGE=true
PROBE_CRON_SECRET=replace-with-a-long-random-token

# Optional threshold tuning for the public status badge.
LLM_TTFT_DEGRADED_MS=3000
LLM_TPS_DEGRADED_BELOW=5

# Optional KV binding variable name in EdgeOne Pages should be:
# LLM_MONITOR_KV
